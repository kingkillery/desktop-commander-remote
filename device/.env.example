# Copy to .env and fill in values

# WebSocket URL of the Pi hub (use Tailscale IP)
DC_HUB_URL=ws://100.x.x.x:3001

# API key from the hub (~/.desktop-commander-hub/api-keys.json on Pi)
DC_HUB_API_KEY=your-uuid-api-key-here

# Optional: stable device identifier (auto-generated UUID if not set)
# DC_DEVICE_ID=my-windows-pc

# Optional: friendly device name (defaults to hostname)
# DC_DEVICE_NAME=My Windows Machine
