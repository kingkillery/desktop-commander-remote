# Hub server ports
PORT=3000
WS_PORT=3001

# ── Cloud deployment (docker compose --profile cloud) ─────────────────────────
# Tailscale auth key — generate at https://login.tailscale.com/admin/settings/keys
# Use an ephemeral+reusable key for cloud VMs; use a non-ephemeral key to keep
# the Tailscale node across container restarts.
TS_AUTHKEY=tskey-auth-REPLACE_ME

# Tailscale hostname for this hub (shows up in your Tailscale admin as this name)
TS_HOSTNAME=dc-remote-hub

# Network mode when sharing Tailscale's network namespace
HUB_NETWORK_MODE=service:tailscale
